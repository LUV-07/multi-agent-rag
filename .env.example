# ============================================================
# Copy this file to .env and fill in your values
# Get FREE Groq API key at: https://console.groq.com
# ============================================================

# --- Groq API (FREE) ---
# Sign up at https://console.groq.com → API Keys → Create
GROQ_API_KEY=your_groq_api_key_here

# --- Model Settings ---
# Free Groq models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
LLM_MODEL=llama3-8b-8192

# --- Embedding Settings ---
# Free local model (downloads once ~90MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- RAG Settings ---
CHUNK_SIZE=512
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MAX_TOKENS=1024

# --- App Settings ---
APP_TITLE=Multi-Agent RAG
DEBUG=false
